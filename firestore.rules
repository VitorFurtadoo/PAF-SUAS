rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // HELPER FUNCTIONS
    function isSignedIn() {
      // Using email as requirement, verification relaxed for compatibility
      return request.auth != null && request.auth.token.email != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.matches('(?i)conieoliveira@gmail\\.com') ||
        getUserRole() == 'ADMIN' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : 'GUEST';
    }

    function getUserUnit() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.unidadeCras : 'N/A';
    }

    // ENTITY VALIDATIONS
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'role', 'unidadeCras', 'createdAt']) &&
             data.email is string && data.email.size() <= 200 &&
             data.name is string && data.name.size() <= 200 &&
             data.role in ['TECNICO', 'COORDENADOR', 'ADMIN'] &&
             data.unidadeCras is string && data.unidadeCras.size() <= 100 &&
             data.createdAt is timestamp;
    }

    function isValidPAF(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.createdAt is timestamp &&
             (data.numeroPlano is string && data.numeroPlano.size() <= 100) &&
             (data.unidadeCras is string && data.unidadeCras.size() <= 200) &&
             (data.responsavel is string && data.responsavel.size() <= 500) &&
             (data.cpf is string && data.cpf.size() <= 50) &&
             (data.situacao is string && data.situacao.size() <= 100);
    }

    function isValidFicha(data) {
      return data.keys().hasAll(['unidadeCras', 'dataAtendimento', 'responsavelFamiliar', 'tecnicoId', 'tecnicoNome', 'tipoAtendimento', 'descricao', 'createdAt']) &&
             data.unidadeCras is string && data.unidadeCras.size() <= 200 &&
             data.dataAtendimento is string && data.dataAtendimento.size() <= 100 &&
             data.responsavelFamiliar is string && data.responsavelFamiliar.size() <= 500 &&
             data.tecnicoId is string && data.tecnicoId == request.auth.uid &&
             data.tecnicoNome is string && data.tecnicoNome.size() <= 500 &&
             data.tipoAtendimento is list && data.tipoAtendimento.size() > 0 &&
             data.descricao is string && data.descricao.size() <= 50000 &&
             data.createdAt is timestamp;
    }

    function isValidBenefit(data) {
      return data.keys().hasAll(['familiaId', 'responsavel', 'unidadeCras', 'tipoBeneficio', 'tecnicoId', 'createdAt']) &&
             data.familiaId is string &&
             data.responsavel is string &&
             data.unidadeCras is string &&
             data.tipoBeneficio is string &&
             data.tecnicoId is string &&
             data.createdAt is timestamp;
    }

    function isValidNotice(data) {
      return data.keys().hasAll(['title', 'content', 'type', 'active', 'authorId', 'authorName', 'createdAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 5000 &&
             data.type in ['INFO', 'WARNING', 'IMPORTANT', 'ACHIEVEMENT'] &&
             data.active is bool &&
             data.authorId is string &&
             data.authorName is string &&
             data.createdAt is timestamp;
    }

    // RULES
    match /users/{userId} {
      allow get: if isSignedIn() && (userId == request.auth.uid || isAdmin() || getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO']);
      allow list: if isSignedIn() && (isAdmin() || getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO']);
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming()) && incoming().role == 'TECNICO';
      allow update: if isSignedIn() && (isAdmin() || userId == request.auth.uid) && isValidUser(incoming());
    }

    match /pafs/{pafId} {
      allow get: if isSignedIn() && (
        isAdmin() || 
        resource.data.userId == request.auth.uid || 
        (getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO'] && resource.data.unidadeCras == getUserUnit())
      );
      
      allow list: if isSignedIn() && (
        isAdmin() || 
        (getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO'] && (resource.data.unidadeCras == getUserUnit() || getUserRole() == 'ADMIN'))
      );

      allow create: if isSignedIn() 
                    && isValidId(pafId)
                    && isValidPAF(incoming())
                    && incoming().userId == request.auth.uid
                    && (isAdmin() || getUserRole() == 'ADMIN' || incoming().unidadeCras == getUserUnit())
                    && incoming().createdAt == request.time;

      allow update: if isSignedIn()
                    && isValidId(pafId)
                    && (
                      isAdmin() ||
                      resource.data.userId == request.auth.uid ||
                      (getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO'] && resource.data.unidadeCras == getUserUnit())
                    )
                    && isValidPAF(incoming())
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt
                    && (incoming().updatedAt == request.time || incoming().updatedAt == existing().updatedAt);

      allow delete: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /fichas_atendimento/{fichaId} {
      allow get: if isSignedIn() && (
        resource.data.tecnicoId == request.auth.uid ||
        isAdmin() ||
        (getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO'] && resource.data.unidadeCras == getUserUnit())
      );
      
      allow list: if isSignedIn() && (
        isAdmin() || 
        (getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO'] && (resource.data.unidadeCras == getUserUnit() || getUserRole() == 'ADMIN'))
      );

      allow create: if isSignedIn()
                    && isValidId(fichaId)
                    && isValidFicha(incoming())
                    && (isAdmin() || getUserRole() == 'ADMIN' || incoming().unidadeCras == getUserUnit())
                    && incoming().createdAt == request.time;

      allow update: if isSignedIn()
                    && (isAdmin() || resource.data.tecnicoId == request.auth.uid)
                    && isValidFicha(incoming())
                    && incoming().tecnicoId == existing().tecnicoId
                    && incoming().createdAt == existing().createdAt;
    }

    match /acoesCras/{acaoId} {
      allow read: if isSignedIn() && (isAdmin() || getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO']);
      allow create, update: if isSignedIn() && (isAdmin() || getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO']);
      allow delete: if isAdmin();
    }

    match /suggestions/{suggestionId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /bug_reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /planejamentos/{planejamentoId} {
      allow read: if isSignedIn() && (isAdmin() || getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO']);
      allow create, update: if isSignedIn() && (isAdmin() || getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO']);
      allow delete: if isAdmin() || (isSignedIn() && getUserRole() == 'COORDENADOR' && resource.data.unidadeCras == getUserUnit());
    }

    match /benefit_concessions/{concessionId} {
      allow get: if isSignedIn() && (request.auth.uid == 'WJ6s3Yr5VnTXt0dYDchPghhg3Y33' || isAdmin() || getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO']);
      allow list: if isSignedIn() && (request.auth.uid == 'WJ6s3Yr5VnTXt0dYDchPghhg3Y33' || isAdmin() || getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO']);
      allow create: if isSignedIn() && (isAdmin() || getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO']) && isValidBenefit(incoming());
      allow update: if isSignedIn() && (isAdmin() || getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO']) && (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['responsavel', 'unidadeCras', 'tipoBeneficio', 'especificacao', 'quantidade', 'valorEstimado', 'observacao']));
      allow delete: if isAdmin();
    }
    
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }

    match /notices/{noticeId} {
      allow read: if isSignedIn() && (isAdmin() || (resource != null && resource.data.active == true));
      allow create: if isAdmin() && isValidNotice(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidNotice(incoming()) && (incoming().updatedAt == request.time || incoming().updatedAt == existing().updatedAt);
      allow delete: if isAdmin();
    }
  }
}
