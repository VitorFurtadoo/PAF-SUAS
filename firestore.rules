rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // HELPER FUNCTIONS
    function isSignedIn() {
      // Using verified email as a strict requirement for writes
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "conieoliveira@gmail.com"
      );
    }

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return getUser().role;
    }

    function getUserUnit() {
      return getUser().unidadeCras;
    }

    // ENTITY VALIDATIONS
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'role', 'unidadeCras', 'createdAt']) &&
             data.email is string && data.email.size() <= 200 &&
             data.name is string && data.name.size() <= 200 &&
             data.role in ['TECNICO', 'COORDENADOR', 'ADMIN'] &&
             data.unidadeCras is string && data.unidadeCras.size() <= 100 &&
             data.createdAt is timestamp;
    }

    function isValidPAF(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             (data.numeroPlano is string && data.numeroPlano.size() <= 50) &&
             (data.unidadeCras is string && data.unidadeCras.size() <= 100) &&
             (data.responsavel is string && data.responsavel.size() <= 200) &&
             (data.cpf is string && data.cpf.size() <= 20) &&
             (data.telefone is string && data.telefone.size() <= 30) &&
             (data.endereco is string && data.endereco.size() <= 500) &&
             (data.situacao is string && data.situacao.size() <= 50) &&
             (data.membros is list && data.membros.size() <= 50) &&
             (data.history is list && data.history.size() <= 200) &&
             (!data.keys().contains('tasks') || (data.tasks is list && data.tasks.size() <= 100)) &&
             (!data.keys().contains('vulnerabilidades') || (data.vulnerabilidades is list && data.vulnerabilidades.size() <= 100)) &&
             (!data.keys().contains('situacoes') || (data.situacoes is list && data.situacoes.size() <= 100)) &&
             (!data.keys().contains('metasFamilia') || (data.metasFamilia is list && data.metasFamilia.size() <= 100)) &&
             (!data.keys().contains('metasEquipe') || (data.metasEquipe is list && data.metasEquipe.size() <= 100));
    }

    function isValidFicha(data) {
      return data.keys().hasAll(['unidadeCras', 'dataAtendimento', 'responsavelFamiliar', 'tecnicoId', 'tecnicoNome', 'tipoAtendimento', 'descricao', 'createdAt']) &&
             data.unidadeCras is string && data.unidadeCras.size() <= 100 &&
             data.dataAtendimento is string && data.dataAtendimento.size() <= 20 &&
             data.responsavelFamiliar is string && data.responsavelFamiliar.size() <= 200 &&
             data.tecnicoId is string && data.tecnicoId == request.auth.uid &&
             data.tecnicoNome is string && data.tecnicoNome.size() <= 200 &&
             data.tipoAtendimento is list && data.tipoAtendimento.size() > 0 &&
             data.descricao is string && data.descricao.size() <= 10000 &&
             data.createdAt is timestamp;
    }

    // RULES
    match /users/{userId} {
      allow get: if isSignedIn() && (userId == request.auth.uid || isAdmin() || getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO']);
      allow list: if isSignedIn() && (isAdmin() || getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO']);
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming()) && incoming().role == 'TECNICO';
      allow update: if isSignedIn() && (isAdmin() || userId == request.auth.uid) && isValidUser(incoming());
    }

    match /pafs/{pafId} {
      allow get: if isSignedIn() && (
        isAdmin() || 
        resource.data.userId == request.auth.uid || 
        (getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO'] && resource.data.unidadeCras == getUserUnit())
      );
      
      allow list: if isSignedIn() && (
        isAdmin() || 
        (getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO'] && (resource.data.unidadeCras == getUserUnit() || getUserUnit() == 'Administração'))
      );

      allow create: if isSignedIn() 
                    && isValidId(pafId)
                    && isValidPAF(incoming())
                    && incoming().userId == request.auth.uid
                    && (isAdmin() || getUserUnit() == 'Administração' || incoming().unidadeCras == getUserUnit())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;

      allow update: if isSignedIn()
                    && isValidId(pafId)
                    && (
                      isAdmin() ||
                      resource.data.userId == request.auth.uid ||
                      (getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO'] && resource.data.unidadeCras == getUserUnit())
                    )
                    && isValidPAF(incoming())
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt
                    && (incoming().updatedAt == request.time || incoming().updatedAt == existing().updatedAt);

      allow delete: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /fichas_atendimento/{fichaId} {
      allow get: if isSignedIn() && (
        resource.data.tecnicoId == request.auth.uid ||
        isAdmin() ||
        (getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO'] && resource.data.unidadeCras == getUserUnit())
      );
      
      allow list: if isSignedIn() && (
        isAdmin() || 
        (getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO'] && (resource.data.unidadeCras == getUserUnit() || getUserUnit() == 'Administração'))
      );

      allow create: if isSignedIn()
                    && isValidId(fichaId)
                    && isValidFicha(incoming())
                    && (isAdmin() || getUserUnit() == 'Administração' || incoming().unidadeCras == getUserUnit())
                    && incoming().createdAt == request.time;

      allow update: if isSignedIn()
                    && (isAdmin() || resource.data.tecnicoId == request.auth.uid)
                    && isValidFicha(incoming())
                    && incoming().tecnicoId == existing().tecnicoId
                    && incoming().createdAt == existing().createdAt;
    }

    match /acoesCras/{acaoId} {
      allow read: if isSignedIn() && (isAdmin() || getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO']);
      allow create, update: if isSignedIn() && (isAdmin() || getUserRole() in ['ADMIN', 'COORDENADOR', 'TECNICO']);
      allow delete: if isAdmin();
    }

    match /suggestions/{suggestionId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /bug_reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }
    
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }
  }
}
